--format "(bestaudio[acodec^=opus]/bestaudio)/best"
--verbose
--force-ipv4
--sleep-requests 1
--sleep-interval 5
--max-sleep-interval 30
--ignore-errors
--no-continue
--no-overwrites
--add-metadata
--parse-metadata "%(title)s:%(meta_title)s"
--parse-metadata "%(uploader)s:%(meta_artist)s"
--write-description
--write-info-json
--write-annotations
--write-thumbnail
--embed-thumbnail
--extract-audio
--check-formats
--concurrent-fragments 5
--match-filter "!is_live & !live"
--download-archive /app/data/archives/audioonly.archive
--throttled-rate 100K
--batch-file "/app/data/config/lists/audioonly.list"
--output "/app/data/output/audioonly/%(playlist)s/(%(uploader)s) - %(upload_date)s - %(title)s [%(id)s].%(ext)s"
--cache-dir "/app/data/cache/"