--verbose
--force-ipv4
--sleep-requests 1
--sleep-interval 5
--max-sleep-interval 30
--ignore-errors
--no-continue
--no-overwrites
--add-metadata
--throttled-rate 100K
--parse-metadata "%(title)s:%(meta_title)s"
--parse-metadata "%(uploader)s:%(meta_artist)s"
--write-description
--write-info-json
--write-annotations
--write-thumbnail
--embed-thumbnail
--all-subs
--embed-subs
--check-formats
--concurrent-fragments 5
--match-filter "!is_live & !live"
--merge-output-format "mkv"
--download-archive /app/data/archives/playlist.archive
--batch-file "/app/data/config/lists/playlists.list"
--output "/app/data/output/playlists/%(playlist)s/%(uploader)s - %(title)s - %(upload_date)s [%(id)s].%(ext)s"
--cache-dir "/app/data/cache/"